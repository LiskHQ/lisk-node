# OP_NODE_L1_TRUST_RPC allows for faster syncing, but should be used *only* if your L1 RPC node
# is fully trusted. It also allows op-node to work with clients such as Erigon that do not
# support storage proofs:
# OP_NODE_L1_TRUST_RPC=true

# SNAP SYNC
# NOTE: Snap sync requires reachable peers via the discovery protocol. If no bootnodes/peers are available, sync may stall or fail to start. We recommend running a full or archive node for production.
